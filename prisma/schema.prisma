// Prisma schema for Blackbox AI — Campaign Orchestrator
// Connected to Supabase Postgres DB

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  campaigns   Campaign[]
  leads       Lead[]
  senders     Sender[]
  auditLogs   AuditLog[]
  integrations Integration[]

  @@map("users")
}

model Lead {
  id          String   @id @default(cuid())
  email       String
  firstName   String?
  lastName    String?
  company     String?
  country     String?
  city        String?
  industry    String?
  consent     Boolean  @default(false) // Compliance: opt-in required
  consentDate DateTime?
  source      String   // e.g., "upload", "integration"
  sendStatus  String   @default("pending") // pending, sent, failed, suppressed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  campaigns Campaign[]
  sendJobs  SendJob[]

  @@map("leads")
}

model Campaign {
  id            String   @id @default(cuid())
  name          String
  description   String?
  status        String   @default("draft") // draft, active, paused, completed
  country       String?
  city          String?
  industry      String?
  senderPoolId  String?
  throttling    Json?    // e.g., { "rate": 10, "interval": "minute" }
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  userId   String
  user     User     @relation(fields: [userId], references: [id])
  leads    Lead[]
  sender   Sender?  @relation(fields: [senderPoolId], references: [id])

  @@map("campaigns")
}

model Sender {
  id          String   @id @default(cuid())
  provider    String   // e.g., "gmail", "sendgrid", "mailgun"
  email       String
  name        String?
  quota       Int      @default(100) // Daily send quota
  usedQuota   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId     String
  user       User       @relation(fields: [userId], references: [id])
  campaigns  Campaign[]

  @@map("senders")
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // e.g., "send", "compliance_check", "campaign_create"
  details   Json?
  userId    String?
  createdAt DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Integration {
  id          String   @id @default(cuid())
  provider    String   // e.g., "clearbit", "hunter", "linkedin"
  config      Json     // API keys, settings
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("integrations")
}

model SuppressionList {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String   // e.g., "bounce", "complaint", "unsubscribe"
  source    String   // e.g., "provider", "manual"
  createdAt DateTime @default(now())

  @@map("suppression_list")
}

model SendJob {
  id          String   @id @default(cuid())
  campaignId  String
  leadId      String
  status      String   @default("queued") // queued, sent, failed, suppressed
  provider    String?  // e.g., "gmail", "sendgrid"
  error       String?
  sentAt      DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  campaign Campaign @relation(fields: [campaignId], references: [id])
  lead     Lead     @relation(fields: [leadId], references: [id])

  @@map("send_jobs")
}

model WebhookEvent {
  id        String   @id @default(cuid())
  provider  String   // e.g., "sendgrid", "mailgun"
  event     String   // e.g., "delivered", "bounce", "complaint"
  payload   Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("webhook_events")
}
