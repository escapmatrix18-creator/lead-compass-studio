# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# Feature Flags
VITE_FEATURE_ENABLE_CRAWLER_UI=false
VITE_FEATURE_ENABLE_PROXY_UI=false
VITE_FEATURE_ENABLE_ANALYTICS=true
VITE_FEATURE_ENABLE_TELEMETRY=true

# UI Configuration  
VITE_DEFAULT_THEME=light
VITE_ENABLE_ANIMATIONS=true
VITE_MASK_PII=true
VITE_CONSENT_REQUIRED=true
VITE_SHOW_RATE_LIMIT_NOTICE=true

# Development
VITE_ENABLE_MOCKING=true
VITE_PREFETCH_ROUTES=true

# i18n
VITE_I18N_DEFAULT_LANG=en