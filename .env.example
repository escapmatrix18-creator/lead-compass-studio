# Campaign Studio Environment Variables

# API Configuration
VITE_API_BASE_URL=http://localhost:3001/api
VITE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/callback

# Supabase Configuration (Optional - for authentication and database)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email Provider Settings (Examples - these would be handled by backend)
# SENDGRID_API_KEY=your_sendgrid_api_key
# MAILGUN_API_KEY=your_mailgun_api_key
# GMAIL_CLIENT_ID=your_gmail_oauth_client_id
# GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret

# Analytics & Monitoring (Optional)
# VITE_GOOGLE_ANALYTICS_ID=your_ga_id
# VITE_SENTRY_DSN=your_sentry_dsn

# Feature Flags (Optional)
# VITE_ENABLE_DEBUG_MODE=false
# VITE_ENABLE_MOCK_DATA=true